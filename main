        { id:'rdl',       name:'Romanian Deadlift', weight:20, rdl:true, note:'taze kaslarla' },
        { id:'face-pull', name:'Face Pull',         weight:25 },
        { id:'low-back',  name:'Lower Back',        weight:50 },
      ],
      'd4-core': [
        { id:'plank-5',  name:'Plank',              weight:null, detail:'3 × 45 sn' },
        { id:'deadbug-5',name:'Dead Bug',            weight:null, detail:'3 × 12' },
        { id:'hang-5',   name:'Hanging Knee Raise',  weight:null, detail:'3 × 12' },
      ]
    },
    progBar:'prog-4', progTxt:'prog-text-4', completeBtn:'complete-4', total:9
  },
  5: {
    sections: {
      'd5-exercises': [
        { id:'leg-ext',   name:'Leg Extension', weight:50 },
        { id:'leg-curl',  name:'Leg Curl',      weight:50 },
        { id:'leg-press', name:'Leg Press',     weight:70 },
        { id:'abductor',  name:'Abductor',      weight:50 },
      ],
      'd5-core': [
        { id:'plank-6',  name:'Plank',              weight:null, detail:'3 × 45 sn' },
        { id:'deadbug-6',name:'Dead Bug',            weight:null, detail:'3 × 12' },
        { id:'hang-6',   name:'Hanging Knee Raise',  weight:null, detail:'3 × 12' },
      ]
    },
    progBar:'prog-5', progTxt:'prog-text-5', completeBtn:'complete-5', total:7
  }
};

// ─── STATE ───────────────────────────────────────────────────────
let state = {};
try { state = JSON.parse(localStorage.getItem('wt_state') || '{}'); } catch {}
state.weights   = state.weights   || {};
state.sessions  = state.sessions  || {};
state.checked   = state.checked   || {};
state.completed = state.completed || {};
state.cardio    = state.cardio    || {};

function persist() { localStorage.setItem('wt_state', JSON.stringify(state)); }

let modalDay = null, modalExId = null;
let viewMonth = new Date(); viewMonth.setDate(1);

// ─── WEIGHT ──────────────────────────────────────────────────────
function getW(id, def) { return state.weights[id] !== undefined ? state.weights[id] : def; }

function detailStr(ex) {
  if (ex.weight === null) return ex.detail || '';
  if (ex.multiWeight) return ex.multiWeight + ' kg';
  const w = getW(ex.id, ex.weight);
  return w + ' kg' + (ex.note ? ' — ' + ex.note : '');
}

// ─── RENDER ──────────────────────────────────────────────────────
function renderAll() {
  for (const [di, dayData] of Object.entries(PROGRAM)) {
    const d = parseInt(di);
    for (const [cid, exercises] of Object.entries(dayData.sections)) {
      const container = document.getElementById(cid);
      if (!container) continue;
      container.innerHTML = '';
      exercises.forEach(ex => {
        const done = !!(state.checked[d] && state.checked[d][ex.id]);
        const el = document.createElement('div');
        el.className = 'exercise-card' + (done ? ' done' : '') + (ex.rdl ? ' rdl-card' : '');
        el.id = `card-${d}-${ex.id}`;
        const hasEditBtn = ex.weight !== null && !ex.multiWeight;
        el.innerHTML = `
          <div class="check-area" onclick="toggleEx(${d},'${ex.id}')">
            <div class="check-circle">
              <svg class="check-icon" viewBox="0 0 12 12" fill="none">
                <polyline points="2,6 5,9 10,3" stroke="#0e0e0f" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </div>
          <div class="ex-info" onclick="toggleEx(${d},'${ex.id}')">
            <div class="ex-name">${ex.name}</div>
            <div class="ex-detail" id="det-${d}-${ex.id}">${detailStr(ex)}</div>
          </div>
          ${hasEditBtn ? `<button class="weight-btn" onclick="openModal(${d},'${ex.id}')">✎ kg</button>` : ''}
        `;
        container.appendChild(el);
      });
    }
    updateProgress(d);
    refreshBtn(d);
  }
  for (let i = 0; i < 7; i++) refreshTab(i);
  [1,3].forEach(d => {
    const c = document.getElementById(`cardio-${d}`);
    if (c) c.classList.toggle('done', !!state.cardio[d]);
  });
}

function updateProgress(day) {
  const dd = PROGRAM[day]; if (!dd) return;
  const allIds = Object.values(dd.sections).flat().map(e => e.id);
  const done = allIds.filter(id => state.checked[day] && state.checked[day][id]).length;
  const pct = Math.round((done / dd.total) * 100);
  const bar = document.getElementById(dd.progBar);
  const txt = document.getElementById(dd.progTxt);
  if (bar) bar.style.width = pct + '%';
  if (txt) txt.textContent = `${done} / ${dd.total} tamamlandı`;
}

function refreshBtn(day) {
  const btn = document.getElementById(`complete-${day}`); if (!btn) return;
  if (state.completed[day]) { btn.disabled = true; btn.textContent = '✓ Tamamlandı'; }
  else { btn.disabled = false; btn.textContent = 'Günü Tamamla'; }
}

function refreshTab(i) {
  const tab = document.querySelectorAll('.day-tab')[i]; if (!tab) return;
  tab.classList.toggle('done-tab', !!(state.completed[i] || state.cardio[i]));
}

// ─── INTERACTIONS ────────────────────────────────────────────────
function toggleEx(day, exId) {
  if (!state.checked[day]) state.checked[day] = {};
  state.checked[day][exId] = !state.checked[day][exId];
  const card = document.getElementById(`card-${day}-${exId}`);
  if (card) card.classList.toggle('done', state.checked[day][exId]);
  updateProgress(day);
  persist();
}

function completeDay(day) {
  const dd = PROGRAM[day];
  const allIds = Object.values(dd.sections).flat().map(e => e.id);
  const done = allIds.filter(id => state.checked[day] && state.checked[day][id]).length;
  if (done < dd.total) { showToast(`${dd.total - done} egzersiz kaldı`); return; }
  state.completed[day] = true;
  const today = todayKey();
  if (!state.sessions[today]) state.sessions[today] = { volume:0, cardio:false };
  state.sessions[today].volume = calcVolume(day);
  persist();
  refreshBtn(day);
  refreshTab(day);
  showToast('Gün tamamlandı! 💪');
}

function resetDay(day) {
  state.checked[day] = {};
  state.completed[day] = false;
  persist();
  renderAll();
  showToast('Sıfırlandı');
}

function toggleCardio(day) {
  state.cardio[day] = !state.cardio[day];
  const card = document.getElementById(`cardio-${day}`);
  if (card) card.classList.toggle('done', state.cardio[day]);
  const today = todayKey();
  if (!state.sessions[today]) state.sessions[today] = { volume:0, cardio:false };
  state.sessions[today].cardio = state.cardio[day];
  persist();
  refreshTab(day);
  if (state.cardio[day]) showToast('Harika! 🏊');
}

function calcVolume(day) {
  const dd = PROGRAM[day]; if (!dd) return 0;
  return Object.values(dd.sections).flat()
    .filter(e => e.weight !== null)
    .reduce((sum, e) => sum + getW(e.id, e.weight), 0);
}

// ─── MODAL ───────────────────────────────────────────────────────
function openModal(day, exId) {
  modalDay = day; modalExId = exId;
  const ex = Object.values(PROGRAM[day].sections).flat().find(e => e.id === exId);
  if (!ex) return;
  document.getElementById('modal-ex-name').textContent = ex.name;
  document.getElementById('modal-weight-input').value = getW(exId, ex.weight);
  document.getElementById('weight-modal').classList.add('open');
}

function closeModal() {
  document.getElementById('weight-modal').classList.remove('open');
  modalDay = null; modalExId = null;
}

function stepWeight(d) {
  const inp = document.getElementById('modal-weight-input');
  inp.value = Math.max(0, parseFloat(inp.value || 0) + d);
}

function saveWeight() {
  if (modalDay === null) return;
  const val = parseFloat(document.getElementById('modal-weight-input').value);
  state.weights[modalExId] = val;
  const ex = Object.values(PROGRAM[modalDay].sections).flat().find(e => e.id === modalExId);
  const det = document.getElementById(`det-${modalDay}-${modalExId}`);
  if (det && ex) det.textContent = detailStr({ ...ex, weight: val });
  persist();
  closeModal();
  showToast('Ağırlık güncellendi ✓');
}

document.getElementById('weight-modal').addEventListener('click', e => { if (e.target.id === 'weight-modal') closeModal(); });

// ─── NAVIGATION ──────────────────────────────────────────────────
function switchDay(i) {
  document.querySelectorAll('.day-view').forEach((v,j) => v.classList.toggle('active', i===j));
  document.querySelectorAll('.day-tab').forEach((t,j) => t.classList.toggle('active', i===j));
  document.getElementById('current-day-label').textContent = ['Gün 1','Gün 2','Gün 3','Gün 4','Gün 5','Gün 6','Gün 7'][i];
}

function switchScreen(name) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById('screen-'+name).classList.add('active');
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('nav-'+name).classList.add('active');
  if (name === 'metrics') renderMetrics();
}

// ─── METRICS ─────────────────────────────────────────────────────
const MONTHS = ['Ocak','Şubat','Mart','Nisan','Mayıs','Haziran','Temmuz','Ağustos','Eylül','Ekim','Kasım','Aralık'];
const WDAYS  = ['Pzt','Sal','Çar','Per','Cum','Cmt','Paz'];

function changeMonth(d) { viewMonth.setMonth(viewMonth.getMonth()+d); renderMetrics(); }

function renderMetrics() {
  const y = viewMonth.getFullYear(), m = viewMonth.getMonth();
  document.getElementById('month-label').textContent = `${MONTHS[m]} ${y}`;
  const prefix = `${y}-${String(m+1).padStart(2,'0')}`;
  const sessions = Object.entries(state.sessions)
    .filter(([k]) => k.startsWith(prefix))
    .map(([k,v]) => ({ date:k, ...v }));

  document.getElementById('stat-workouts').textContent = sessions.filter(s => s.volume > 0).length;
  document.getElementById('stat-cardio').textContent   = sessions.filter(s => s.cardio).length;
  document.getElementById('stat-volume').textContent   = sessions.reduce((a,s) => a+(s.volume||0), 0);
  document.getElementById('stat-total').textContent    = new Set(sessions.map(s => s.date)).size;

  // Bar chart — weekly volume
  const chart = document.getElementById('volume-chart');
  chart.innerHTML = '';
  const weeksVol = [0,0,0,0,0];
  sessions.forEach(s => {
    const day = parseInt(s.date.split('-')[2]);
    weeksVol[Math.min(Math.floor((day-1)/7), 4)] += (s.volume||0);
  });
  const maxV = Math.max(...weeksVol, 1);
  const now = new Date();
  const curWeek = Math.min(Math.floor((now.getDate()-1)/7), 4);
  weeksVol.forEach((v,i) => {
    const isCur = now.getFullYear()===y && now.getMonth()===m && i===curWeek;
    const wrap = document.createElement('div');
    wrap.className = 'bar-wrap';
    wrap.innerHTML = `<div class="bar${isCur?' current':''}" style="height:${Math.round((v/maxV)*100)}%"></div><div class="bar-lbl">H${i+1}</div>`;
    chart.appendChild(wrap);
  });

  // Calendar
  const grid = document.getElementById('cal-grid');
  grid.innerHTML = '';
  WDAYS.forEach(d => {
    const l = document.createElement('div');
    l.className = 'cal-day-label'; l.textContent = d; grid.appendChild(l);
  });
  const firstDow = (new Date(y,m,1).getDay()+6)%7;
  for (let i=0; i<firstDow; i++) {
    const e = document.createElement('div'); e.className='cal-cell empty'; grid.appendChild(e);
  }
  const daysInMonth = new Date(y,m+1,0).getDate();
  const sesMap = {}; sessions.forEach(s => sesMap[s.date]=s);
  for (let d=1; d<=daysInMonth; d++) {
    const key = `${y}-${String(m+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    const s = sesMap[key];
    const isToday = now.getFullYear()===y && now.getMonth()===m && now.getDate()===d;
    let cls = 'cal-cell';
    if (s && s.volume>0) cls += ' workout';
    else if (s && s.cardio) cls += ' cardio';
    if (isToday) cls += ' today';
    const cell = document.createElement('div');
    cell.className = cls; cell.textContent = d; grid.appendChild(cell);
  }
}

// ─── UTILS ───────────────────────────────────────────────────────
function todayKey() {
  const d = new Date();
  return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
}

let toastTimer;
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => t.classList.remove('show'), 2200);
}

renderAll();
</script>
</body>
</html>
